   "source": [
    "# we live we love we XGBoost\n",
    "# i am so normal about this prediction interval\n",
    "#  Value at Risk & Expected Shortfall",
    "# We compute empirical (historical) VaR — more robust than parametric",
    "",
    "confidence_levels = [0.90, 0.95, 0.99]",
    "",
    "print('')",
    "print('          QUANTITATIVE RISK METRICS — XGBoost            ')",
    "print('')",
    "print(f'  Prediction Volatility (σ):  ₹{residuals.std()/1e5:>7.1f} Lakhs           ')",
    "print('')",
    "",
    "var_results = {}",
    "cvar_results = {}",
    "",
    "for cl in confidence_levels:",
    "# VaR: the error we expect NOT to exceed (1-cl)% of the time",
    "var = np.percentile(abs_residuals, cl * 100)",
    "# CVaR (Expected Shortfall): mean of losses beyond VaR",
    "cvar = abs_residuals[abs_residuals >= var].mean()",
    "var_results[cl] = var",
    "cvar_results[cl] = cvar",
    "print(f'  VaR ({int(cl*100):2d}%):  ₹{var/1e5:>7.1f}L  |  CVaR:  ₹{cvar/1e5:>7.1f}L        ')",
    "",
    "print('')",
    "print()",
    "print(' Interpretation:')",
    "print(f'  • 95% VaR = ₹{var_results[0.95]/1e5:.1f}L → model prediction error will be < ₹{var_results[0.95]/1e5:.1f}L, 95% of the time')",
    "print(f'  • 95% CVaR = ₹{cvar_results[0.95]/1e5:.1f}L → when it goes wrong, the average error is ₹{cvar_results[0.95]/1e5:.1f}L')"
